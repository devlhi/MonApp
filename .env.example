# ====== AppMon Configuration ======
# Server
PORT=3000
HOST=0.0.0.0
JWT_SECRET=change_this_secret

# Database file (SQLite)
DB_PATH=./data/appmon.db

# Monitoring intervals (milliseconds)
PING_INTERVAL=5000
MIKROTIK_INTERVAL=5000

# Ping settings
PING_TIMEOUT=2
PING_COUNT=1

# SLA: rolling window for uptime stats (hours)
SLA_WINDOW_HOURS=24

# History retention (days) - older samples get pruned
HISTORY_RETENTION_DAYS=30

# Default RouterOS API port (8728 plain / 8729 TLS)
MIKROTIK_DEFAULT_PORT=8728
